import arcpy, os ROOT = r"C:\Users\mccul\OneDrive\Professional Information\Resume Items\WhiteRockFloodProject" GDB  = os.path.join(ROOT, "Data", "GIS", "WhiteRock.gdb") bg   = os.path.join(GDB, "Demographics", "FC_BlockGroups")  print("Fields in FC_BlockGroups:") for f in arcpy.ListFields(bg):     if "GEO" in f.name.upper() or "GEOID" in f.name.upper() or "FIPS" in f.name.upper():         print("  " + f.name + " (type: " + f.type + ", length: " + str(f.length) + ")")  print("") print("First 3 GEOID values:") fields = [f.name for f in arcpy.ListFields(bg)] print("  All fields: " + str(fields)) with arcpy.da.SearchCursor(bg, [fields[1], fields[2]]) as cur:     for i, row in enumerate(cur):         print("  " + str(row))         if i >= 2:             break
import arcpy, os  ROOT = r"C:\Users\mccul\OneDrive\Professional Information\Resume Items\WhiteRockFloodProject" GDB  = os.path.join(ROOT, "Data", "GIS", "WhiteRock.gdb") bg   = os.path.join(GDB, "Demographics", "FC_BlockGroups")  arcpy.env.overwriteOutput = True  # Total population (B01003_001E) arcpy.management.CalculateField(bg, "POP_TOTAL", "!B01003_001E!", "PYTHON3") print("OK POP_TOTAL")  # Housing units (B25001_001E) arcpy.management.CalculateField(bg, "HU_TOTAL", "!B25001_001E!", "PYTHON3") print("OK HU_TOTAL")  # Median household income (B19013_001E) arcpy.management.CalculateField(bg, "MED_INC", "!B19013_001E!", "PYTHON3") print("OK MED_INC")  # Percent below poverty # B17001_002E = population below poverty, B17001_001E = total population for poverty universe arcpy.management.CalculateField(bg, "PCT_POVERTY",     "round(!B17001_002E! / !B17001_001E! * 100, 2) if !B17001_001E! and !B17001_001E! > 0 else None",     "PYTHON3") print("OK PCT_POVERTY")  # Percent no vehicle # B08201_002E = households with no vehicle, B08201_001E = total households arcpy.management.CalculateField(bg, "PCT_NO_VEH",     "round(!B08201_002E! / !B08201_001E! * 100, 2) if !B08201_001E! and !B08201_001E! > 0 else None",     "PYTHON3") print("OK PCT_NO_VEH")  # Percent age 65+ -- sum male 65+ and female 65+ age buckets from B01001 # Male 65+: B01001_020E through B01001_025E # Female 65+: B01001_044E through B01001_049E arcpy.management.CalculateField(bg, "PCT_65PLUS", """ def calc(m20,m21,m22,m23,m24,m25,f44,f45,f46,f47,f48,f49,total):     if not total or total == 0:         return None     over65 = (m20 or 0)+(m21 or 0)+(m22 or 0)+(m23 or 0)+(m24 or 0)+(m25 or 0)+ \              (f44 or 0)+(f45 or 0)+(f46 or 0)+(f47 or 0)+(f48 or 0)+(f49 or 0)     return round(over65 / total * 100, 2) calc(!B01001_020E!,!B01001_021E!,!B01001_022E!,!B01001_023E!,!B01001_024E!,!B01001_025E!,      !B01001_044E!,!B01001_045E!,!B01001_046E!,!B01001_047E!,!B01001_048E!,!B01001_049E!,      !B01003_001E!) """, "PYTHON3") print("OK PCT_65PLUS")  print("") print("All SVI input fields calculated. Verify values look reasonable:") with arcpy.da.SearchCursor(bg, ["POP_TOTAL","HU_TOTAL","MED_INC",                                  "PCT_POVERTY","PCT_NO_VEH","PCT_65PLUS"]) as cur:     for i, row in enumerate(cur):         print("  " + str(row))         if i >= 4:             break
