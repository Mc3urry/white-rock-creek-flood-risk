import arcpy, os  root = r"C:\WhiteRockFloodProject"  folders = [     "Data/GIS/BaseData", "Data/GIS/FloodHazards", "Data/GIS/Demographics",     "Data/GIS/Infrastructure", "Data/GIS/Hydrology",     "Data/HECRAS/Geometry", "Data/HECRAS/Terrain", "Data/HECRAS/Results",     "Data/HECRAS/Plans", "Data/HECRAS/Exports",     "Python", "Maps", "Report/Figures", "Report/Tables",     "WebGIS", "Documentation", "GitHub" ]  for f in folders:     os.makedirs(os.path.join(root, f), exist_ok=True)  # Create geodatabase gdb = os.path.join(root, "Data/GIS/WhiteRock.gdb") arcpy.management.CreateFileGDB(os.path.dirname(gdb), "WhiteRock.gdb")  # Set coordinate system — NAD83 / Texas State Plane North Central (feet) sr = arcpy.SpatialReference(2276)  # Create feature datasets datasets = ["BaseData","Hydrology","Infrastructure","Demographics","FloodHazards","Analysis","FinalProducts"] for ds in datasets:     arcpy.management.CreateFeatureDataset(gdb, ds, sr)  print("Folder structure and geodatabase created successfully.")
