import arcpy, os GDB = r"C:\Users\mccul\OneDrive\Professional Information\Resume Items\WhiteRockFloodProject\Data\GIS\WhiteRock.gdb" fema = os.path.join(GDB, "FloodHazards", "FC_FEMA_FloodZones_WS")  zones_100yr = ('A', 'AE', 'AO', 'AH') tot = 0 found_zones = {} with arcpy.da.SearchCursor(fema, ["SHAPE@AREA", "FLD_ZONE"]) as c:     for area, zone in c:         found_zones[zone] = found_zones.get(zone, 0) + area/43560         if zone in zones_100yr:             tot += area  tot_acres = tot / 43560 print("All zones present in your FEMA layer (acres):") for z, a in sorted(found_zones.items()):     print(f"  {z}: {a:,.0f}") print() print(f"FEMA 100-yr floodplain (A+AE+AO+AH): {tot_acres:,.0f} acres") print(f"Modeled: 13,480 | Difference: {13480-tot_acres:,.0f} ac ({(13480-tot_acres)/tot_acres*100:.0f}%)")
