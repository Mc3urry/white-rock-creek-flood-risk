import arcpy, os  ROOT = r"C:\Users\mccul\OneDrive\Professional Information\Resume Items\WhiteRockFloodProject" GDB  = os.path.join(ROOT, "Data", "GIS", "WhiteRock.gdb") COUNTY = os.path.join(ROOT, "Data", "GIS", "BaseData", "DallasCountyBoundary", "DallasCounty_Boundary.shp")  # Use ArcGIS Online feature service instead of the full GeoJSON # Microsoft publishes buildings as a public REST service buildings_url = "https://services.arcgis.com/P3ePLMYs2RVChkJx/arcgis/rest/services/Microsoft_Building_Footprints/FeatureServer/0"  out_fc = os.path.join(GDB, "BaseData", "FC_Buildings")  print("Clipping buildings from Microsoft REST service...") arcpy.conversion.ExportFeatures(     buildings_url,     out_fc,     where_clause="",     use_field_alias_as_name="NOT_USE_ALIAS", ) print("Done")
import arcpy, os  ROOT   = r"C:\Users\mccul\OneDrive\Professional Information\Resume Items\WhiteRockFloodProject" GDB    = os.path.join(ROOT, "Data", "GIS", "WhiteRock.gdb") CSV    = os.path.join(ROOT, "Data", "GIS", "BaseData", "FC_Buildings.csv") OUT_FC = os.path.join(GDB, "BaseData", "FC_Buildings")  # Convert CSV to point feature class using LONGITUDE and LATITUDE columns arcpy.management.XYTableToPoint(     in_table          = CSV,     out_feature_class = OUT_FC,     x_field           = "LONGITUDE",     y_field           = "LATITUDE",     coordinate_system = arcpy.SpatialReference(4326) )  # Reproject to WKID 2276 (TX State Plane feet) OUT_PROJ = os.path.join(GDB, "BaseData", "FC_Buildings_Proj") arcpy.management.Project(OUT_FC, OUT_PROJ, arcpy.SpatialReference(2276))  # Replace unprojected with projected arcpy.management.Delete(OUT_FC) arcpy.management.Rename(OUT_PROJ, OUT_FC)  count = int(arcpy.management.GetCount(OUT_FC)[0]) print(f"✓ FC_Buildings created — {count:,} building points in WKID 2276")
